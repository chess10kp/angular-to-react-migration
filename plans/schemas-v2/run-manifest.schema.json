{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mx://schemas/v2/run-manifest.schema.json",
  "schemaVersion": "2.0.0",
  "title": "RunManifest",
  "description": "Audit record of exactly what one agent task received (was: ContextPackManifest). The pack itself is the concatenation of items in order. Framework-neutral in v1; v2 adds schemaVersion and records the active source/target framework parameters so any run is reproducible independent of framework.",
  "type": "object",
  "required": ["schemaVersion", "packId", "role", "taskType", "unitId", "items", "tokenEstimate", "budget"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2.0.0" },
    "packId": { "type": "string", "description": "sha256 of the ordered item hashes." },
    "runId": { "type": "string" },
    "sourceFramework": { "$ref": "common.schema.json#/$defs/frameworkDescriptor" },
    "targetFramework": { "$ref": "common.schema.json#/$defs/frameworkDescriptor" },
    "role": { "type": "string" },
    "taskType": { "type": "string" },
    "unitId": { "type": ["string", "null"] },
    "promptTemplate": { "type": "string" },
    "modelTier": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "ref", "sha256"],
        "properties": {
          "kind": { "enum": ["role-card", "task-instruction", "unit-record", "legacy-source", "template", "recipe", "scenario", "lesson", "conventions", "failure-artifact", "trace-excerpt", "counterexample", "patch", "adapter-descriptor", "phase-doc-section", "other"] },
          "ref": { "type": "string" },
          "sha256": { "type": "string" },
          "tokens": { "type": "integer" }
        }
      }
    },
    "tokenEstimate": { "type": "integer" },
    "budget": { "type": "integer" },
    "overflowed": { "type": "boolean", "default": false },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
