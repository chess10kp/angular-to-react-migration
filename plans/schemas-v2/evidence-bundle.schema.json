{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mx://schemas/v2/evidence-bundle.schema.json",
  "schemaVersion": "2.0.0",
  "title": "EvidenceBundle",
  "description": "NEW in v2. A content-addressed set of artifacts submitted to satisfy one gate, plus the mechanical check results the harness re-computed over them. v1 scattered evidence as inline {path,sha256} arrays on ledger events and gate submissions; v2 promotes it to a first-class, hash-verifiable bundle so gate decisions are fully auditable. Framework-neutral.",
  "type": "object",
  "required": ["schemaVersion", "bundleId", "unitId", "gate", "items"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2.0.0" },
    "bundleId": { "type": "string" },
    "unitId": { "$ref": "common.schema.json#/$defs/unitId" },
    "gate": { "$ref": "common.schema.json#/$defs/gateId" },
    "submittedBy": {
      "type": "object",
      "properties": { "role": { "type": "string" }, "agentId": { "type": "string" }, "leaseId": { "type": "string" } }
    },
    "submittedAt": { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "allOf": [ { "$ref": "common.schema.json#/$defs/evidenceRefBase" } ],
        "properties": {
          "role": {
            "description": "What this artifact proves for the gate.",
            "enum": ["build-log", "typecheck-report", "lint-report", "unit-test-report", "story-render", "seam-mount-report", "parity-report", "trace", "trace-diff", "counterexample", "critic-verdict", "smoke-report", "soak-report", "usage-scan", "coverage", "other"]
          }
        },
        "unevaluatedProperties": false
      }
    },
    "checks": {
      "type": "array",
      "description": "Mechanical results the harness RE-RAN over the items (it does not trust agent-reported results). Gate passes only if all required checks pass.",
      "items": {
        "type": "object",
        "required": ["name", "passed"],
        "properties": {
          "name": { "type": "string", "description": "e.g. 'tsc', 'eslint', 'unit-tests', 'story-smoke', 'trace-diff-empty', 'console-errors-zero'." },
          "passed": { "type": "boolean" },
          "exitCode": { "type": "integer" },
          "detail": { "type": "string" },
          "artifact": { "$ref": "common.schema.json#/$defs/evidenceRef" }
        }
      }
    },
    "targetAdapter": {
      "description": "Optional target-framework-specific evidence (e.g. Angular2+ build stats, bundle-size deltas, Module Federation remote wiring proof).",
      "$ref": "adapter-ref.schema.json"
    }
  }
}
