{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mx://schemas/v2/counterexample.schema.json",
  "schemaVersion": "2.0.0",
  "title": "Counterexample",
  "description": "A structured, minimal description of one behavioral divergence between the legacy and target twins. Divergence kinds are framework-neutral. `suspectedConstruct` is free text (neutral hints like 'derived-state-ordering', 'content-projection-slot', 'scheduler-vs-microtask-timing'), with any framework-specific root-cause classification carried in `analysis.sourceAdapter`.",
  "type": "object",
  "required": ["schemaVersion", "ceId", "unitId", "scenarioId", "status", "divergence", "fingerprint"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "const": "2.0.0" },
    "ceId": { "type": "string", "pattern": "^ce-[0-9]{6}$" },
    "unitId": { "type": "string" },
    "scenarioId": { "type": "string" },
    "status": { "enum": ["open", "analyzing", "directed", "fix-claimed", "closed-fixed", "closed-waived", "closed-invalid", "reopened"] },
    "reopenCount": { "type": "integer", "minimum": 0 },
    "fingerprint": { "type": "string", "description": "sha256 of (scenarioId | divergence.kind | first divergent semanticKey). Same fingerprint reopening twice after a claimed fix triggers automatic escalation." },
    "divergence": {
      "type": "object",
      "required": ["kind", "stepIndex", "legacyEvidence", "targetEvidence"],
      "properties": {
        "kind": { "enum": ["missing-event", "extra-event", "order", "payload-mismatch", "aria-mismatch", "dom-mismatch", "url-mismatch", "console-error", "timing-semantic", "focus-order", "visual"] },
        "stepIndex": { "type": "integer" },
        "firstDivergentSemanticKey": { "type": "string" },
        "legacyEvidence": { "type": "object", "properties": { "tracePath": { "type": "string" }, "seqRange": { "type": "array", "items": { "type": "integer" } }, "excerpt": { "type": "array" } } },
        "targetEvidence": { "type": "object", "properties": { "tracePath": { "type": "string" }, "seqRange": { "type": "array", "items": { "type": "integer" } }, "excerpt": { "type": "array" } } },
        "reproducibility": { "type": "object", "properties": { "runs": { "type": "integer" }, "reproduced": { "type": "integer" } } }
      }
    },
    "analysis": {
      "type": "object",
      "description": "Filled by counterexample-analyst.",
      "properties": {
        "minimalRepro": { "type": "array", "description": "Shortest userSteps prefix that reproduces (from trace.bisect)." },
        "suspectedConstruct": { "type": "string", "description": "Free-text neutral root-cause hint, e.g. 'derived-state-ordering', 'content-projection-slot', 'debounced-model-update', 'scheduler-vs-microtask-timing'. Framework-specific classification goes in sourceAdapter." },
        "explanation": { "type": "string", "maxLength": 2000 },
        "sourceAdapter": {
          "description": "Optional framework-specific root-cause classification (e.g. Angular2+ 'onpush-change-detection-miss' / 'rxjs-subscription-leak' / 'zone-vs-microtask-timing').",
          "$ref": "adapter-ref.schema.json"
        },
        "repairDirective": {
          "type": "object",
          "required": ["targetArtifact", "expectedObservable"],
          "properties": {
            "targetArtifact": { "type": "string" },
            "fixDirection": { "type": "string" },
            "expectedObservable": { "type": "string" },
            "relevantRecipeSection": { "type": "string" },
            "relevantLessons": { "type": "array", "items": { "type": "string" } }
          }
        },
        "waiverRecommended": { "type": "boolean" }
      }
    },
    "resolution": {
      "type": "object",
      "properties": {
        "kind": { "enum": ["fixed", "waived", "invalid"] },
        "evidence": { "type": "array", "items": { "type": "object", "properties": { "path": { "type": "string" }, "sha256": { "type": "string" } } } },
        "decisionId": { "type": "string", "description": "DecisionRecord id if a waiver/decision resolved this (v1: waiverId)." },
        "lessonId": { "type": "string" }
      }
    }
  }
}
