{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mx://schemas/behavior-ir.schema.json",
  "title": "BehaviorIRScenario",
  "description": "Framework-neutral specification of one user-observable scenario. The exam a React unit must pass. Must be green against the legacy app before it counts (gate G1).",
  "type": "object",
  "required": ["scenarioId", "unitIds", "route", "preconditions", "userSteps", "expected", "status"],
  "additionalProperties": false,
  "properties": {
    "scenarioId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]+$" },
    "title": { "type": "string" },
    "unitIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "route": { "type": "string" },
    "priority": { "enum": ["critical-path", "core", "edge"], "default": "core" },
    "source": {
      "description": "How this scenario was derived — matters for trust weighting.",
      "enum": ["recorded-session", "trace-mined", "authored", "crawler", "mutation-gap"]
    },
    "preconditions": {
      "type": "object",
      "properties": {
        "auth": { "type": "string", "description": "Named auth profile from fixtures" },
        "fixtureProfile": { "type": "string", "description": "MSW/network fixture profile id" },
        "viewport": { "type": "string", "default": "1280x800" },
        "clock": { "type": "string", "description": "Frozen ISO timestamp if the flow is time-sensitive" },
        "seed": { "type": "integer", "description": "Deterministic seed if randomness involved" },
        "localStorage": { "type": "object" }
      },
      "required": ["fixtureProfile"]
    },
    "userSteps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action"],
        "properties": {
          "action": { "enum": ["navigate", "click", "fill", "select", "press", "hover", "drag", "upload", "waitForSettle", "assertCheckpoint"] },
          "url": { "type": "string" },
          "role": { "type": "string", "description": "ARIA role for locating the element" },
          "name": { "type": "string", "description": "Accessible name" },
          "selector": { "type": "string", "description": "Fallback CSS selector; use role+name when possible" },
          "value": { "type": "string" },
          "key": { "type": "string" },
          "checkpoint": { "type": "string", "description": "Named intermediate assertion group from expected.checkpoints" }
        }
      }
    },
    "expected": {
      "type": "object",
      "properties": {
        "aria": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string" },
              "name": { "type": "string" },
              "contains": { "type": "string" },
              "count": { "type": "integer" },
              "focusOrder": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "dom": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "selector": { "type": "string" },
              "count": { "type": "integer" },
              "textEquals": { "type": "string" },
              "allTextEquals": { "type": "string" },
              "visible": { "type": "boolean" }
            }
          }
        },
        "network": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["method", "path"],
            "properties": {
              "method": { "type": "string" },
              "path": { "type": "string" },
              "query": { "type": "object" },
              "bodyContains": { "type": "object" },
              "orderMatters": { "type": "boolean", "default": false }
            }
          }
        },
        "semantic": {
          "type": "array",
          "description": "Domain events emitted through the semantic-event probe (shim on legacy, event layer on target).",
          "items": {
            "type": "object",
            "required": ["event"],
            "properties": { "event": { "type": "string" }, "payload": { "type": "object" } }
          }
        },
        "url": { "type": "object", "properties": { "path": { "type": "string" }, "query": { "type": "object" } } },
        "consoleErrors": { "type": "integer", "const": 0 },
        "checkpoints": {
          "type": "object",
          "description": "Named intermediate assertion groups referenced by assertCheckpoint steps.",
          "additionalProperties": { "$ref": "#/properties/expected" }
        }
      }
    },
    "legacyTraceRefs": { "type": "array", "items": { "type": "string" }, "description": "Baseline trace runs backing this scenario" },
    "status": {
      "type": "object",
      "required": ["greenOnLegacy"],
      "properties": {
        "greenOnLegacy": { "type": "boolean" },
        "lastLegacyRun": { "type": "string" },
        "calibration": {
          "type": "object",
          "properties": {
            "mutantsInjected": { "type": "integer" },
            "mutantsKilled": { "type": "integer" },
            "acceptedGaps": { "type": "array", "items": { "type": "string" } }
          }
        },
        "flakeScreen": { "type": "object", "properties": { "runs": { "type": "integer" }, "passes": { "type": "integer" } } }
      }
    }
  }
}
