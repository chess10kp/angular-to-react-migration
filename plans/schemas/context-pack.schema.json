{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mx://schemas/context-pack.schema.json",
  "title": "ContextPackManifest",
  "description": "Audit record of exactly what one agent task received. Written by the orchestrator at pack-assembly time; the pack itself is the concatenation of items in order.",
  "type": "object",
  "required": ["packId", "role", "taskType", "unitId", "items", "tokenEstimate", "budget"],
  "properties": {
    "packId": { "type": "string", "description": "sha256 of the ordered item hashes" },
    "role": { "type": "string" },
    "taskType": { "type": "string", "description": "e.g. convert, repair, author-scenarios, analyze-ce" },
    "unitId": { "type": ["string", "null"] },
    "promptTemplate": { "type": "string", "description": "plans/prompts/<file> used" },
    "modelTier": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "ref", "sha256"],
        "properties": {
          "kind": { "enum": ["role-card", "task-instruction", "unit-record", "legacy-source", "template", "recipe", "scenario", "lesson", "conventions", "failure-artifact", "trace-excerpt", "counterexample", "phase-doc-section", "other"] },
          "ref": { "type": "string", "description": "path or path#section" },
          "sha256": { "type": "string" },
          "tokens": { "type": "integer" }
        }
      }
    },
    "tokenEstimate": { "type": "integer" },
    "budget": { "type": "integer" },
    "overflowed": { "type": "boolean", "default": false },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
