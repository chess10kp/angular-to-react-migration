{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mx://schemas/counterexample.schema.json",
  "title": "Counterexample",
  "description": "A structured, minimal description of one behavioral divergence between the legacy and target twins. Opened by the verifier (mechanical), enriched by the counterexample-analyst, consumed by the repairer.",
  "type": "object",
  "required": ["ceId", "unitId", "scenarioId", "status", "divergence", "fingerprint"],
  "additionalProperties": false,
  "properties": {
    "ceId": { "type": "string", "pattern": "^ce-[0-9]{6}$" },
    "unitId": { "type": "string" },
    "scenarioId": { "type": "string" },
    "status": { "enum": ["open", "analyzing", "directed", "fix-claimed", "closed-fixed", "closed-waived", "closed-invalid", "reopened"] },
    "reopenCount": { "type": "integer", "minimum": 0 },
    "fingerprint": {
      "type": "string",
      "description": "sha256 of (scenarioId | divergence.kind | first divergent semanticKey). Same fingerprint reopening twice after a claimed fix triggers automatic escalation (01 §3.3)."
    },
    "divergence": {
      "type": "object",
      "required": ["kind", "stepIndex", "legacyEvidence", "targetEvidence"],
      "properties": {
        "kind": { "enum": ["missing-event", "extra-event", "order", "payload-mismatch", "aria-mismatch", "dom-mismatch", "url-mismatch", "console-error", "timing-semantic", "focus-order", "visual"] },
        "stepIndex": { "type": "integer" },
        "firstDivergentSemanticKey": { "type": "string" },
        "legacyEvidence": { "type": "object", "properties": { "tracePath": { "type": "string" }, "seqRange": { "type": "array", "items": { "type": "integer" } }, "excerpt": { "type": "array" } } },
        "targetEvidence": { "type": "object", "properties": { "tracePath": { "type": "string" }, "seqRange": { "type": "array", "items": { "type": "integer" } }, "excerpt": { "type": "array" } } },
        "reproducibility": { "type": "object", "properties": { "runs": { "type": "integer" }, "reproduced": { "type": "integer" } } }
      }
    },
    "analysis": {
      "type": "object",
      "description": "Filled by counterexample-analyst.",
      "properties": {
        "minimalRepro": { "type": "array", "description": "Shortest userSteps prefix that reproduces (from trace.bisect)" },
        "suspectedConstruct": { "type": "string", "description": "e.g. 'watcher-ordering', 'transclusion-slot', 'debounce-model-option', 'digest-vs-microtask-timing'" },
        "explanation": { "type": "string", "maxLength": 2000 },
        "repairDirective": {
          "type": "object",
          "required": ["targetArtifact", "expectedObservable"],
          "properties": {
            "targetArtifact": { "type": "string", "description": "File expected to change" },
            "fixDirection": { "type": "string" },
            "expectedObservable": { "type": "string", "description": "What in the trace will look different when fixed" },
            "relevantRecipeSection": { "type": "string" },
            "relevantLessons": { "type": "array", "items": { "type": "string" } }
          }
        },
        "waiverRecommended": { "type": "boolean", "description": "True when legacy behavior is judged to be the bug" }
      }
    },
    "resolution": {
      "type": "object",
      "properties": {
        "kind": { "enum": ["fixed", "waived", "invalid"] },
        "evidence": { "type": "array", "items": { "type": "object", "properties": { "path": { "type": "string" }, "sha256": { "type": "string" } } } },
        "waiverId": { "type": "string" },
        "lessonId": { "type": "string", "description": "Set if librarian distilled a lesson from this CE" }
      }
    }
  }
}
