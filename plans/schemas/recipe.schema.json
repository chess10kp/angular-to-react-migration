{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mx://schemas/recipe.schema.json",
  "title": "RecipeFrontmatter",
  "description": "YAML frontmatter of migration/recipes/<id>.md. The markdown body carries the human/agent-readable procedure: Preconditions, Steps, Target pattern (canonical code), Pitfalls, Verification emphasis, Worked exemplar (before/after).",
  "type": "object",
  "required": ["id", "status", "motifs", "appliesTo", "exemplar", "version"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^r-[0-9]{3}[a-z0-9-]*$" },
    "title": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "verified", "revised", "deprecated"] },
    "motifs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "appliesTo": {
      "type": "object",
      "properties": {
        "unitKinds": { "type": "array", "items": { "enum": ["route", "component", "directive", "service", "filter"] } },
        "signature": { "type": "string", "description": "Machine-checkable precondition, e.g. a grep/AST pattern the unit's source must match" },
        "preconditions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "exemplar": {
      "type": "object",
      "required": ["unitId"],
      "properties": {
        "unitId": { "type": "string" },
        "beforePaths": { "type": "array", "items": { "type": "string" } },
        "afterPaths": { "type": "array", "items": { "type": "string" } },
        "verifiedAtLedgerSeq": { "type": "integer" }
      }
    },
    "codemod": {
      "type": ["object", "null"],
      "description": "Optional deterministic pre-transform run before the agent works.",
      "properties": { "script": { "type": "string" }, "coverage": { "enum": ["full", "partial-scaffold"] } }
    },
    "pitfalls": { "type": "array", "items": { "type": "string" } },
    "verificationEmphasis": { "type": "array", "items": { "type": "string" }, "description": "Divergence kinds this motif historically produces; verifier weights these" },
    "stats": {
      "type": "object",
      "description": "Maintained by orchestrator in recipes/stats.json, mirrored here on revision.",
      "properties": {
        "applied": { "type": "integer" },
        "firstPassParity": { "type": "integer" },
        "avgRepairLoops": { "type": "number" },
        "escalations": { "type": "integer" }
      }
    }
  }
}
