{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mx://schemas/ledger-event.schema.json",
  "title": "LedgerEvent",
  "type": "object",
  "required": ["seq", "ts", "actor", "type"],
  "properties": {
    "seq": { "type": "integer" },
    "ts": { "type": "string", "format": "date-time" },
    "actor": {
      "type": "object",
      "required": ["role"],
      "properties": { "role": { "type": "string" }, "agentId": { "type": "string" }, "human": { "type": "string" } }
    },
    "unitId": { "type": "string" },
    "type": {
      "enum": ["transition", "claim", "release", "lease-expired", "gate-fail", "counterexample-opened",
               "counterexample-closed", "waiver-granted", "waiver-rejected", "escalation", "escalation-resolved",
               "drift-invalidation", "tombstone", "recipe-created", "recipe-revised", "lesson-added",
               "budget-updated", "pack-overflow", "flake-suspect", "ratchet-adjusted", "note"]
    },
    "from": { "type": "string" },
    "to": { "type": "string" },
    "gate": { "type": "string", "pattern": "^G[1-8]$" },
    "evidence": {
      "type": "array",
      "items": { "type": "object", "required": ["path", "sha256"], "properties": { "path": { "type": "string" }, "sha256": { "type": "string" } } }
    },
    "payload": { "type": "object" },
    "note": { "type": "string", "maxLength": 1000 }
  }
}
