{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mx://schemas/parity/parity-case.schema.json",
  "schemaVersion": "1.0.0",
  "title": "ParityCase",
  "description": "One framework-neutral behavioral test recipe scoped to a single migration unit. Says WHAT to do and WHAT to observe; never how a framework bootstraps (that is an adapter/workbench concern). A lighter, component-scoped sibling of BehaviorScenario.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "unitId", "caseId", "steps"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "unitId": { "type": "string", "minLength": 1 },
    "caseId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
    "title": { "type": "string" },
    "env": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "viewport": { "type": "string", "pattern": "^[0-9]+x[0-9]+$" },
        "locale": { "type": "string" },
        "seed": { "type": "integer" }
      }
    },
    "fixtureProfile": { "type": "string" },
    "initialInputs": { "type": "object" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action"],
        "properties": {
          "action": {
            "enum": ["setInputs", "click", "fill", "press", "resize", "advanceClock", "waitForSettle", "checkpoint"]
          },
          "inputs": { "type": "object" },
          "role": { "type": "string" },
          "name": { "type": "string" },
          "selector": { "type": "string" },
          "value": { "type": "string" },
          "key": { "type": "string" },
          "width": { "type": "number" },
          "height": { "type": "number" },
          "ms": { "type": "number" }
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "visibleText": { "type": "array", "items": { "type": "string" } },
          "aria": { "type": "array", "items": { "type": "object" } },
          "events": { "type": "array", "items": { "type": "object" } },
          "noConsoleErrors": { "type": "boolean" },
          "styles": { "type": "array", "items": { "type": "object" } }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "channels": { "type": "array", "items": { "type": "string" } },
        "orderMatters": { "type": "boolean" },
        "ignoreStyleKeys": { "type": "array", "items": { "type": "string" } },
        "looseText": { "type": "boolean" }
      }
    }
  }
}
