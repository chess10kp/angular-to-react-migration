{
  "name": "@migration/parity-harness",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Cross-framework parity harness: run one framework-neutral ParityCase against an Angular baseline and a React target, then diff normalized observations (not HTML).",
  "bin": { "parity": "./src/cli.ts" },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json",
    "parity": "tsx src/cli.ts"
  },
  "dependencies": {
    "@angular/common": "17.3.9",
    "@angular/compiler": "17.3.9",
    "@angular/core": "17.3.9",
    "@angular/platform-browser": "17.3.9",
    "@angular/platform-browser-dynamic": "17.3.9",
    "jsdom": "25.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zone.js": "0.14.10"
  },
  "devDependencies": {
    "@types/jsdom": "21.1.7",
    "@types/node": "22.5.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "tsx": "4.19.0",
    "typescript": "5.4.5",
    "vitest": "2.0.5"
  }
}
